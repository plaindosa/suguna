{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application, potentially an admin.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Quote": {
      "title": "Quote",
      "description": "A quote request submitted by a customer.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The customer's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The customer's email address."
        },
        "phone": {
          "type": "string",
          "description": "The customer's phone number."
        },
        "requirements": {
          "type": "string",
          "description": "The project requirements."
        },
        "fileName": {
          "type": "string",
          "description": "The name of the uploaded file."
        },
        "fileData": {
          "type": "string",
          "description": "Base64 encoded file data."
        },
        "fileType": {
          "type": "string",
          "description": "MIME type of the uploaded file."
        },
        "status": {
          "type": "string",
          "enum": ["new", "reviewed", "contacted"],
          "description": "The status of the quote request."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the quote was submitted."
        }
      },
      "required": ["name", "email", "phone", "requirements", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and roles."
    },
    "/quotes/{quoteId}": {
      "schema": {
        "$ref": "#/entities/Quote"
      },
      "description": "Stores quote requests from customers."
    }
  }
}
